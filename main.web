FILE 1: style.css 
================================================== 
 body { 
font-family: Arial, sans-serif; margin: 0; background-color: #f4f4f4; 
} 
 header { 
background-color: #333; color: white; padding: 15px; text-align: center; 
} 
 nav a { 
color: white; margin: 10px; text-decoration: none; font-weight: bold; 
} 
 
.container { padding: 20px; 
} 
 
.products { display: flex; gap: 20px; flex-wrap: wrap; 
} 
 
.product { background: white; padding: 15px; width: 220px; border-radius: 10px; box-shadow: 0 0 8px gray; text-align: center; 
} 
 
.product img { width: 180px; height: 180px; 
} 
 button { 
padding: 10px 15px; background-color: green; color: white; border: none; border-radius: 5px; cursor: pointer; 
} 
 button:hover { 
background-color: darkgreen; 
} 
 footer { 
background-color: #333; color: white; text-align: center; padding: 10px; margin-top: 20px; 
} 
 input, textarea { padding: 8px; width: 250px; 
} 
 
